# Adna Light Theme for btop
# Analogous purple base + mint complementary accent (color theory based)
# Background: #F0F3FF, Primary: #836FFF, Accent: #15F5BA, FG: #211951

theme[main_bg]="#F0F3FF"
theme[main_fg]="#211951"
theme[title]="#15F5BA"
theme[hi_fg]="#15F5BA"
theme[selected_fg]="#F0F3FF"
theme[selected_bg]="#836FFF"
theme[inactive_fg]="#5A527F"
theme[proc_misc]="#5A527F"
theme[cpu_box]="#15F5BA"
theme[mem_box]="#15F5BA"
theme[net_box]="#15F5BA"
theme[proc_box]="#15F5BA"
theme[div_line]="#D8DFFD"

# Temperature gradient (purples)
theme[temp_start]="#382988"
theme[temp_mid]="#614FC9"
theme[temp_end]="#836FFF"

# CPU gradient (purples)
theme[cpu_start]="#382988"
theme[cpu_mid]="#614FC9"
theme[cpu_end]="#836FFF"

# Free memory (mint success)
theme[free_start]="#53F7CC"
theme[free_mid]="#15F5BA"
theme[free_end]="#06926D"

# Cached (subtle purple)
theme[cached_start]="#BCB2FF"
theme[cached_mid]="#836FFF"
theme[cached_end]="#614FC9"

# Available (mid to dark purple)
theme[available_start]="#836FFF"
theme[available_mid]="#614FC9"
theme[available_end]="#382988"

# Used (warning to error gradient)
theme[used_start]="#B8860B"
theme[used_mid]="#C71F4A"
theme[used_end]="#382988"

# Download (mint accent - positive action)
theme[download_start]="#53F7CC"
theme[download_mid]="#15F5BA"
theme[download_end]="#06926D"

# Upload (purple - distinguishing from download)
theme[upload_start]="#836FFF"
theme[upload_mid]="#614FC9"
theme[upload_end]="#382988"
